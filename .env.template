# OpenAI API key (used by the direct `query` command)
OPENAI_API_KEY=your_openai_api_key_here

# Qwen.ai API key (used by the ReAct `agent` command)
# Free tier available at https://dashscope.aliyuncs.com/
# International endpoint (outside China):
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Available models: qwen-turbo (fastest/free), qwen-plus (recommended), qwen-max (most capable)
QWEN_MODEL=qwen-plus

# Storage paths
LANCEDB_PATH=./lancedb
AUDIO_DIR=./audio_files

# Chunking configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Models
EMBEDDING_MODEL=all-MiniLM-L6-v2
LLM_MODEL=gpt-3.5-turbo
WHISPER_MODEL=base

# Response configuration
DEFAULT_MAX_TOKENS=1000
DEFAULT_TEMPERATURE=0.0
